igation from '../components/Navigation';\r\nimport { NavLink } from 'react-router-dom';\r\n\r\nconst Menu = () => {\r\n\r\n    return (\r\n        <section>\r\n            <main>\r\n                <h1>Menu</h1>\r\n                <section className=\"main-container\">\r\n                    <section className=\"menu-list\">\r\n                        <div>\r\n                            <NavLink exact=\"true\" to=\"/menu/yakitori\">\r\n                                <img src=\"https://www.sushifreshparis.fr/images/top-nav/icon-67.png\"></img>\r\n                                <h2>Yakitori</h2>\r\n                            </NavLink>\r\n                        </div>\r\n                        <div>\r\n                            <NavLink exact=\"true\" to=\"/menu/sushi\">\r\n                                <img src=\"https://www.sushifreshparis.fr/images/top-nav/icon-3.png\"></img>\r\n                                <h2>Sushi</h2>\r\n                            </NavLink>\r\n                        </div>\r\n                    </section>\r\n                </section>\r\n            </main>\r\n            <Navigation />\r\n        </section>\r\n    );\r\n};\r\n\r\nexport default Menu;","C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\Home.js",[],"C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\NotFound.js",[],"C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\Commande.js",["56","57"],"import Navigation from '../components/Navigation';\r\n\r\nconst test = ['2', '1'];\r\nconst Commander = () => {\r\n    return (\r\n        <section>\r\n            <main>\r\n                <h1>Order</h1>\r\n                <section className=\"main-container\">\r\n                    <iframe className=\"py-2\" src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2625.807402717264!2d2.335876415673801!3d48.84281227928596!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47e671c38bfd6d21%3A0x851f9b185ab05a6b!2s80%20Bd%20Saint-Michel%2C%2075006%20Paris%2C%20France!5e0!3m2!1sfr!2sca!4v1642804259208!5m2!1sfr!2sca\" width=\"100%\" height=\"auto\" allowFullScreen=\"\" loading=\"lazy\"></iframe>\r\n                    <p>80 Boulevard Saint-Michel 75006 Paris</p>\r\n                    <section className=\"btn-section\">\r\n                        <div className=\"t-color-1 btn\">Sur place</div>\r\n                        <div className=\"t-color-1 btn\">Livraison</div>\r\n                    </section>\r\n                        <h3>Paiement</h3>\r\n                    <section className=\"btn-section\">\r\n                        <div className=\"t-color-1 btn\">Carte de crédit</div>\r\n                        <div className=\"t-color-1 btn\">Carte de débit</div>\r\n                    </section>\r\n                </section>\r\n            </main>\r\n            <Navigation />\r\n        </section>\r\n    );\r\n};\r\n\r\nexport default Commander;","C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\menu\\Yakitori.js",["58"],"C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\components\\Dish.js",["59","60"],"import React, { useState, useEffect } from 'react';\r\nimport menuData from '../components/menuData.json';\r\n\r\nconst Dish = (rawData) => {\r\n    const data = menuData;\r\n    const [playOnce, setPlayOnce] = useState(true);\r\n    const [sortedData, setSortedData] = useState([]);;\r\n\r\n    useEffect(() => {\r\n        if (playOnce) {\r\n            const sortedPrice = () => {\r\n                const sortedArray = rawData.sort((a, b) => {\r\n                    return b.price - a.price\r\n                });\r\n                setSortedData(sortedArray);\r\n            };\r\n            sortedPrice();\r\n            setPlayOnce(false);\r\n        }\r\n    }, [playOnce, data]);\r\n    /* Dishes box */\r\n    let dishBox;\r\n    if (sortedData) {\r\n        dishBox =\r\n            sortedData.map((dish) => (\r\n                <section className=\"dish-card mb-3\" role=\"article\">\r\n                    <h3 key={dish.name}>{dish.name}</h3>\r\n                    <img key={dish.img} src={dish.img} className=\"img-fluid\"></img>\r\n                    <li key={dish}>{dish.price}€</li>\r\n                    <h4 key={dish.pieces}>{dish.pieces} Pièces</h4>\r\n                </section>\r\n                )\r\n            )\r\n\r\n    }\r\n    return (<section>\r\n        {dishBox}\r\n    </section>);\r\n};\r\n\r\nexport default Dish;","C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\components\\Navigation.js",["61","62"],"import React from 'react';\r\nimport { NavLink } from 'react-router-dom';\r\n\r\nconst navigation = () => {\r\n    return (\r\n        <nav className=\"sticky-top bottom-0 w-100\">\r\n            <section className=\"navigation nav-section p-3\">\r\n                <ul className=\"nav justify-content-center\">\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom my-auto me-auto nav-btn\" onClick={() => {\r\n                            const navDisplay = document.querySelector('.nav-display');\r\n                            const main = document.querySelector('main')\r\n                            const navigation = document.querySelector('.navigation');\r\n                            \r\n                            navDisplay.classList.toggle('nav-display-move');\r\n                            main.classList.toggle('blur-effect');\r\n                            navDisplay.style.height = 'calc(100vh - '+ navigation.clientHeight + 'px)'   \r\n                        }\r\n                    } >\r\n                    </li>\r\n                </ul>\r\n            </section>\r\n            <section className=\"nav-display position-fixed w-100 align-content-center d-flex top-0\">\r\n                <ul className=\"m-auto\">\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Menu\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Menu</NavLink> \r\n                    </li>\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Commander\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Commander</NavLink> \r\n                    </li>\r\n                </ul>\r\n            </section>\r\n        </nav>\r\n    );\r\n\r\n};\r\n\r\nexport default navigation;","C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\Menu\\Yakitori.js",[],"C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\pages\\Menu\\Sushi.js",[],{"ruleId":"63","severity":1,"message":"64","line":14,"column":33,"nodeType":"65","endLine":14,"endColumn":102},{"ruleId":"63","severity":1,"message":"64","line":20,"column":33,"nodeType":"65","endLine":20,"endColumn":101},{"ruleId":"66","severity":1,"message":"67","line":3,"column":7,"nodeType":"68","messageId":"69","endLine":3,"endColumn":11},{"ruleId":"70","severity":1,"message":"71","line":10,"column":21,"nodeType":"65","endLine":10,"endColumn":419},{"ruleId":"72","severity":1,"message":"73","line":5,"column":10,"nodeType":"68","messageId":"74","endLine":5,"endColumn":19},{"ruleId":"75","severity":1,"message":"76","line":20,"column":8,"nodeType":"77","endLine":20,"endColumn":24,"suggestions":"78"},{"ruleId":"63","s