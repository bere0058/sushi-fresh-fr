in College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\App.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\reportWebVitals.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\pages\\About.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\pages\\NotFound.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\pages\\Home.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\components\\Logo.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\components\\Navigation.js",["53","54"],"import React from 'react';\r\nimport { NavLink } from 'react-router-dom';\r\n\r\nconst navigation = () => {\r\n    return (\r\n        <nav className=\"sticky-top bottom-0 w-100\">\r\n            <section className=\"navigation nav-section p-3\">\r\n                <ul className=\"nav justify-content-center\">\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom my-auto me-auto nav-btn\" onClick={() => {\r\n                            const navDisplay = document.querySelector('.nav-display');\r\n                            const main = document.querySelector('main')\r\n                            const navigation = document.querySelector('.navigation');\r\n                            \r\n                            navDisplay.classList.toggle('nav-display-move');\r\n                            main.classList.toggle('blur-effect');\r\n                            navDisplay.style.height = 'calc(100vh - '+ navigation.clientHeight + 'px)'   \r\n                        }\r\n                    } >\r\n                    </li>\r\n                </ul>\r\n            </section>\r\n            <section className=\"nav-display position-fixed w-100 align-content-center d-flex top-0\">\r\n                <ul className=\"m-auto\">\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Menu\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Menu</NavLink> \r\n                    </li>\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Commander\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Commander</NavLink> \r\n                    </li>\r\n                </ul>\r\n            </section>\r\n        </nav>\r\n    );\r\n\r\n};\r\n\r\nexport default navigation;","C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\components\\Card.js",[],"C:\\Users\\ccusg\\Documents\\Algonquin College\\Responsive Web Design\\starting-react\\sushi-fresh\\src\\pages\\Menu.js",["55","56","57","58","59","60","61"],"import Navigation from '../components/Navigation';\r\nimport React, { useState, useEffect } from 'react';\r\nimport yakitori from '../assets/yakitori.jpeg';\r\nimport yakisoba from '../assets/yakisoba.jpg';\r\nimport teriyaki from '../assets/teriyaki.jpg';\r\n\r\nconst Menu = (props) => {\r\n    const { dish } = props;\r\n    const [playOnce, setPlayOnce] = useState(true);\r\n    /* const data = menuData;  *