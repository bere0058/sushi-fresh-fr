",[],"C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\components\\Navigation.js",["58","59"],"import React from 'react';\r\nimport { NavLink } from 'react-router-dom';\r\n\r\nconst navigation = () => {\r\n    const navHeight = () => {\r\n        const nav = document.querySelector('nav');\r\n        if (nav) {\r\n            if (nav.clientHeight <= '320') {\r\n                nav.classList.remove('sticky-top');\r\n                nav.classList.add('position-absolute');\r\n            }\r\n        } \r\n    } \r\n    navHeight()\r\n    return (\r\n        <nav className= \"sticky-top bottom-0 w-100\">\r\n            <section className=\"navigation nav-section p-3\">\r\n                <ul className=\"nav justify-content-center\">\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom me-auto\">\r\n                        <NavLink exact=\"true\" to=\"/Cart\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"}  >\r\n                            <div></div>\r\n                        </NavLink>\r\n                    </li>\r\n                    <li className=\"nav-item bg-img-custom my-auto me-auto nav-btn\" onClick={() => {\r\n                            const navDisplay = document.querySelector('.nav-display');\r\n                            const main = document.querySelector('main')\r\n                            const navigation = document.querySelector('.navigation');\r\n                            \r\n                            navDisplay.classList.toggle('nav-display-move');\r\n                            main.classList.toggle('blur-effect');\r\n                            navDisplay.style.height = 'calc(100vh - '+ navigation.clientHeight + 'px)'   \r\n                        }\r\n                    } >\r\n                    </li>\r\n                </ul>\r\n            </section>\r\n            <section className=\"nav-display position-fixed w-100 align-content-center d-flex top-0\">\r\n                <ul className=\"m-auto\">\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Menu\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Menu</NavLink> \r\n                    </li>\r\n                    <li>\r\n                        <NavLink exact=\"true\" to=\"/Commander\" className={({ isActive }) => isActive ? \"nav-active\" : \"\"} className=\"h2\">Commander</NavLink> \r\n                    </li>\r\n                </ul>\r\n            </section>\r\n        </nav>\r\n    );\r\n\r\n};\r\n\r\nexport default navigation;","C:\\Users\\ccusg\\Documents\\Code\\starting-react\\sushi-fresh\\src\\components\\Dish.js",["60"],{"ruleId":"61","replacedBy":"62"},{"ruleId":"63","replacedBy":"64"},{"ruleId":"65","severity":1,"message":"66","line":9,"column":21,"nodeType":"67","endLine":9,"endColumn":419},{"ruleId":"68","severity":1,"message":"69","line":14,"column":33,"nodeType":"67","endLine":14,"endColumn":102},{"ruleId":"68","severity":1,"message":"69","line":20,"column":33,"nodeType":"67","endLine":20,"endColumn":101},{"ruleId":"70","severity":1,"message":"71","line":45,"column":117,"nodeType":"72","messageId":"73","endLine":45,"endColumn":131},{"ruleId":"70","severity":1,"message":"71","line":48,"column":122,"nodeType":"72","messageId":"73","endLine":48,"endColumn":136},{"ruleId":"68","severity":1,"message":"69","line":20,"column":29,"nodeType":"67","endLine":20,"endColumn":86},"no-native-reassign",["74"],"no-negated-in-lhs",["75"],"jsx-a11y/iframe-has-title","<iframe> elements must have a unique title property.","JSXOpeningElement","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an 